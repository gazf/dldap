# コピーして .env を作成してください
# cp .env.example .env

# 必須: 管理者パスワード
LDAP_ADMIN_PW=changeme

# LDAP 設定
LDAP_BASE_DN=dc=example,dc=com
LDAP_ADMIN_DN=cn=admin,dc=example,dc=com

# Samba 設定
# SAMBA_DOMAIN_SID は初回起動時に自動生成されますが、
# 再起動後も同じ SID を使い続けるために固定することを推奨します。
# 初回起動ログに表示された値をここに設定してください。
SAMBA_DOMAIN_SID=S-1-5-21-xxxxxxxxxx-xxxxxxxxxx-xxxxxxxxxx
SAMBA_DOMAIN=WORKGROUP
SAMBA_ENABLED=true
SAMBA_AUTO_HASH=true
SAMBA_LM_HASH=false

# UI → API の接続先 (Docker Compose 内では変更不要)
# CORS_ORIGIN=http://localhost:3000
# API_BASE_URL=http://dldaps-api:8080
